---
import '../styles/global.css';
import { site } from '../lib/site';

interface Props {
  title?: string | undefined;
  description?: string | undefined;
}

const { title, description = `${site.name} — ${site.description}` } = Astro.props;
const fullTitle = title ? `${title} | ${site.name}` : site.name;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <script is:inline>
      // Apply forced theme and chord visibility before first paint.
      const storedTheme = localStorage.getItem('theme');
      if (storedTheme === 'light' || storedTheme === 'dark') {
        document.documentElement.dataset.theme = storedTheme;
      }
      if (localStorage.getItem('chords') === 'on') {
        document.documentElement.dataset.chords = 'on';
      }
    </script>
  </head>
  <body>
    <header class="site-header">
      <a href="/" class="brand">{site.name}</a>
      <a href="/songs/">All songs</a>
      <a href="/artists/">Artists</a>
      <a href="/tags/">Tags</a>
      <button id="chords-toggle" hidden>🎸</button>
      <button id="theme-toggle" hidden>🌓</button>
    </header>
    <main>
      <slot />
    </main>
    <script>
      const toggle = document.getElementById('theme-toggle');
      if (toggle) {
        type Mode = 'system' | 'light' | 'dark';
        const LABELS: Record<Mode, string> = {
          system: '🌓 Auto',
          light: '☀️ Light',
          dark: '🌙 Dark',
        };
        const NEXT: Record<Mode, Mode> = { system: 'light', light: 'dark', dark: 'system' };
        const stored = localStorage.getItem('theme');
        let mode: Mode = stored === 'light' || stored === 'dark' ? stored : 'system';

        const apply = () => {
          if (mode === 'system') {
            delete document.documentElement.dataset.theme;
            localStorage.removeItem('theme');
          } else {
            document.documentElement.dataset.theme = mode;
            localStorage.setItem('theme', mode);
          }
          toggle.textContent = LABELS[mode];
          toggle.setAttribute('aria-label', `Theme: ${mode}. Click to change.`);
        };

        toggle.addEventListener('click', () => {
          mode = NEXT[mode];
          apply();
        });

        apply();
        toggle.hidden = false;
      }

      const chordsToggle = document.getElementById('chords-toggle');
      if (chordsToggle) {
        let chordsOn = localStorage.getItem('chords') === 'on';

        const applyChords = () => {
          if (chordsOn) {
            document.documentElement.dataset.chords = 'on';
            localStorage.setItem('chords', 'on');
            chordsToggle.textContent = '🎸 With chords';
          } else {
            delete document.documentElement.dataset.chords;
            localStorage.setItem('chords', 'off');
            chordsToggle.textContent = '🎸 Without chords';
          }
          chordsToggle.setAttribute('aria-pressed', String(chordsOn));
          chordsToggle.setAttribute(
            'aria-label',
            `Chords ${chordsOn ? 'shown' : 'hidden'}. Click to toggle.`,
          );
        };

        chordsToggle.addEventListener('click', () => {
          chordsOn = !chordsOn;
          applyChords();
        });

        applyChords();
        chordsToggle.hidden = false;
      }
    </script>
  </body>
</html>
