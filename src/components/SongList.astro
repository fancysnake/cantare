---
import type { CollectionEntry } from 'astro:content';
import { locale } from '../lib/i18n';

interface Props {
  songs: CollectionEntry<'songs'>[];
}

const songs = [...Astro.props.songs].sort((a, b) =>
  a.data.title.localeCompare(b.data.title, locale),
);
---

<ul class="song-list">
  {
    songs.map((song) => (
      <li>
        <a href={`/songs/${song.id}/`}>{song.data.title}</a>
        <span class="song-meta"> — {song.data.artist}</span>
      </li>
    ))
  }
</ul>
