---
import { t } from '../lib/i18n';

interface Props {
  urls: string[];
  label?: string | undefined;
}

const { urls, label = t.randomSong } = Astro.props;
---

<button class="btn random-pick" hidden data-urls={JSON.stringify(urls)}>
  🎲 {label}
</button>

<script>
  document.querySelectorAll<HTMLButtonElement>('button.random-pick').forEach((button) => {
    button.hidden = false;
    button.addEventListener('click', () => {
      const urls: string[] = JSON.parse(button.dataset.urls ?? '[]');
      const url = urls[Math.floor(Math.random() * urls.length)];
      if (url) window.location.href = url;
    });
  });
</script>

<style>
  .random-pick {
    padding: 0.4rem 0.9rem;
  }

  @media print {
    .random-pick {
      display: none;
    }
  }
</style>
