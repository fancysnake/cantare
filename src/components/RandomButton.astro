---
interface Props {
  urls: string[];
  label?: string;
}

const { urls, label = 'Pick a random song' } = Astro.props;
---

<button class="random-pick" hidden data-urls={JSON.stringify(urls)}>
  🎲 {label}
</button>

<script>
  document.querySelectorAll<HTMLButtonElement>('button.random-pick').forEach((button) => {
    button.hidden = false;
    button.addEventListener('click', () => {
      const urls: string[] = JSON.parse(button.dataset.urls ?? '[]');
      const url = urls[Math.floor(Math.random() * urls.length)];
      if (url) window.location.href = url;
    });
  });
</script>

<style>
  .random-pick {
    font: inherit;
    color: var(--color-text);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    padding: 0.4rem 0.9rem;
    cursor: pointer;
  }

  .random-pick:hover {
    border-color: var(--color-accent);
  }

  .random-pick:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  @media print {
    .random-pick {
      display: none;
    }
  }
</style>
