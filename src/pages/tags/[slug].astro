---
import { getCollection, type CollectionEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import SongList from '../../components/SongList.astro';
import RandomButton from '../../components/RandomButton.astro';
import { slugify } from '../../lib/slug';

export async function getStaticPaths() {
  const songs = await getCollection('songs');
  const byTag = new Map<string, { name: string; songs: CollectionEntry<'songs'>[] }>();
  for (const song of songs) {
    for (const name of song.data.tags) {
      const slug = slugify(name);
      const entry = byTag.get(slug) ?? { name, songs: [] };
      entry.songs.push(song);
      byTag.set(slug, entry);
    }
  }
  return [...byTag.entries()].map(([slug, props]) => ({ params: { slug }, props }));
}

interface Props {
  name: string;
  songs: CollectionEntry<'songs'>[];
}

const { name, songs } = Astro.props;
---

<Base title={`Tag: ${name} | Cantare`}>
  <h1 data-pagefind-body data-pagefind-meta={`title:Tag: ${name}`}>Tag: {name}</h1>
  <SongList songs={songs} />
  <RandomButton urls={songs.map((song) => `/songs/${song.id}/`)} />
</Base>
