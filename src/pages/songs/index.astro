---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { t } from '../../lib/i18n';

const songs = (await getCollection('songs')).sort((a, b) =>
  a.data.title.localeCompare(b.data.title),
);

const groups = new Map<string, typeof songs>();
for (const song of songs) {
  const letter = song.data.title[0]?.toUpperCase() ?? '#';
  const group = groups.get(letter) ?? [];
  group.push(song);
  groups.set(letter, group);
}
---

<Base title={t.allSongsTitle}>
  <h1>{t.allSongsTitle}</h1>
  {
    [...groups.entries()].map(([letter, group]) => (
      <section>
        <h2>{letter}</h2>
        <ul class="song-list">
          {group.map((song) => (
            <li>
              <a href={`/songs/${song.id}/`}>{song.data.title}</a>
              <span class="song-meta"> — {song.data.artist}</span>
            </li>
          ))}
        </ul>
      </section>
    ))
  }
</Base>
