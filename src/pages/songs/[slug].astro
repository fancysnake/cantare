---
import { getCollection, type CollectionEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { parseSong, renderSong } from '../../lib/song';
import { slugify } from '../../lib/slug';

export async function getStaticPaths() {
  const songs = await getCollection('songs');
  return songs.map((song) => ({ params: { slug: song.id }, props: { song } }));
}

interface Props {
  song: CollectionEntry<'songs'>;
}

const { song } = Astro.props;
const { title, artist, album, key, capo, tags } = song.data;
const sheetHtml = renderSong(parseSong(song.data.source));
---

<Base title={`${title} — ${artist} | Cantare`}>
  <header>
    <h1>{title}</h1>
    <p class="song-meta">
      <a href={`/artists/${slugify(artist)}/`}>{artist}</a>
      {album && <> · <a href={`/albums/${slugify(album)}/`}>{album}</a></>}
      {key && <> · Key: {key}</>}
      {capo !== undefined && <> · Capo: {capo}</>}
    </p>
    {
      tags.length > 0 && (
        <p class="song-meta">
          {tags.map((tag) => (
            <a class="tag" href={`/tags/${slugify(tag)}/`}>
              #{tag}
            </a>
          ))}
        </p>
      )
    }
  </header>
  <article class="chord-sheet" set:html={sheetHtml} />
</Base>
