---
import { getCollection, type CollectionEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import SongList from '../../components/SongList.astro';
import RandomButton from '../../components/RandomButton.astro';
import { slugify } from '../../lib/slug';
import { t } from '../../lib/i18n';

export async function getStaticPaths() {
  const songs = await getCollection('songs');
  const byArtist = new Map<string, { name: string; songs: CollectionEntry<'songs'>[] }>();
  for (const song of songs) {
    const name = song.data.artist;
    const slug = slugify(name);
    const entry = byArtist.get(slug) ?? { name, songs: [] };
    entry.songs.push(song);
    byArtist.set(slug, entry);
  }
  return [...byArtist.entries()].map(([slug, props]) => ({ params: { slug }, props }));
}

interface Props {
  name: string;
  songs: CollectionEntry<'songs'>[];
}

const { name, songs } = Astro.props;
---

<Base title={name}>
  <h1 data-pagefind-body data-pagefind-meta={`title:${t.artistMeta}: ${name}`}>{name}</h1>
  <SongList songs={songs} />
  <RandomButton urls={songs.map((song) => `/songs/${song.id}/`)} />
</Base>
