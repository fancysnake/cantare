---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { slugify } from '../../lib/slug';
import { locale, t } from '../../lib/i18n';

const songs = await getCollection('songs');

const languages = new Map<string, { name: string; count: number }>();
for (const song of songs) {
  const name = song.data.language;
  if (!name) continue;
  const slug = slugify(name);
  const entry = languages.get(slug) ?? { name, count: 0 };
  entry.count += 1;
  languages.set(slug, entry);
}

const sorted = [...languages.entries()].sort((a, b) => a[1].name.localeCompare(b[1].name, locale));
---

<Base title={t.languagesTitle}>
  <h1>{t.languagesTitle}</h1>
  <ul class="song-list">
    {
      sorted.map(([slug, { name, count }]) => (
        <li>
          <a href={`/languages/${slug}/`}>{name}</a>
          <span class="song-meta"> — {t.songCount(count)}</span>
        </li>
      ))
    }
  </ul>
</Base>
