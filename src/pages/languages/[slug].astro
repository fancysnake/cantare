---
import { getCollection, type CollectionEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import SongList from '../../components/SongList.astro';
import RandomButton from '../../components/RandomButton.astro';
import { slugify } from '../../lib/slug';
import { t } from '../../lib/i18n';

export async function getStaticPaths() {
  const songs = await getCollection('songs');
  const byLanguage = new Map<string, { name: string; songs: CollectionEntry<'songs'>[] }>();
  for (const song of songs) {
    const name = song.data.language;
    if (!name) continue;
    const slug = slugify(name);
    const entry = byLanguage.get(slug) ?? { name, songs: [] };
    entry.songs.push(song);
    byLanguage.set(slug, entry);
  }
  return [...byLanguage.entries()].map(([slug, props]) => ({ params: { slug }, props }));
}

interface Props {
  name: string;
  songs: CollectionEntry<'songs'>[];
}

const { name, songs } = Astro.props;
---

<Base title={`${t.languagePrefix}: ${name}`}>
  <h1 data-pagefind-body data-pagefind-meta={`title:${t.languagePrefix}: ${name}`}>
    {t.languagePrefix}: {name}
  </h1>
  <SongList songs={songs} />
  <RandomButton urls={songs.map((song) => `/songs/${song.id}/`)} />
</Base>
