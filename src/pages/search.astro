---
import Base from '../layouts/Base.astro';
---

<Base title="Search | Cantare">
  <h1>Search</h1>
  <link rel="stylesheet" href="/pagefind/pagefind-component-ui.css" />
  <script is:inline type="module" src="/pagefind/pagefind-component-ui.js"></script>
  <noscript>Search requires JavaScript.</noscript>

  <pagefind-input instance="songs"></pagefind-input>
  <div class="search-filters">
    <pagefind-filter-dropdown filter="artist" label="Artist" instance="songs"></pagefind-filter-dropdown>
    <pagefind-filter-dropdown filter="album" label="Album" instance="songs"></pagefind-filter-dropdown>
    <pagefind-filter-dropdown filter="tag" label="Tag" instance="songs"></pagefind-filter-dropdown>
  </div>
  <pagefind-summary instance="songs" default-message="Type to search songs by title or lyrics."></pagefind-summary>
  <pagefind-results instance="songs"></pagefind-results>
</Base>

<style>
  .search-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0.75rem 0;
  }
</style>
